{
  "expo": {
    "name": "MexiPay",
    "slug": "mexipay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "mexipay",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0F0D"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "mx.mexipay.app",
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0F0D"
      },
      "package": "mx.mexipay.app"
    },
    "plugins": [
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#00C87A",
          "sounds": ["./assets/sounds/payment.wav"]
        }
      ],
      [
        "expo-camera",
        { "cameraPermission": "MexiPay necesita acceso a la cámara para escanear códigos QR." }
      ],
      [
        "expo-secure-store"
      ]
    ]
  }
}
