# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mexipay
DB_USER=mexipay
DB_PASS=changeme

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# OAuth — Google
GOOGLE_CLIENT_ID_WEB=xxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_ID_IOS=xxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_ID_ANDROID=xxxxxxxxxx.apps.googleusercontent.com

# OAuth — Apple
# Must match the bundle ID / Service ID registered in Apple Developer Console
APPLE_CLIENT_ID=mx.mexipay.app

# Conekta
CONEKTA_API_KEY=key_xxxxxxxxxx
CONEKTA_WEBHOOK_SECRET=whsec_xxxxxxxxxx
CONEKTA_API_URL=https://api.conekta.io
